# Server Configuration
# This file is for the dashboard process only.
# Device runtime settings such as Wi-Fi SSID/password, APN, and device MQTT credentials
# should be provisioned to the device runtime config, not hardcoded here.
# Copy this file to dashboard/.env and keep real secrets only in that local file.
NODE_ENV=development
PORT=3001
# REQUIRED in production (server refuses to start without it): generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string
DB_PATH=

# MQTT Configuration
# These are the dashboard's broker connection settings.
MQTT_HOST=163.227.6.71
MQTT_PORT=1883
MQTT_PROTOCOL=mqtt
MQTT_USER=deviceuser
MQTT_PASSWORD=your-mqtt-password
MQTT_CLIENT_ID=dashboard-unique-client-id
# Set to 'true' in production when broker has a valid TLS certificate
MQTT_REJECT_UNAUTHORIZED=false

# Phone number formatting (country dial prefix)
PHONE_COUNTRY_CODE=880

# Device Configuration
# Leave blank unless you intentionally want the dashboard to default to one device.
DEVICE_ID=
DEFAULT_DEVICE_ID=

# Dashboard refresh and runtime defaults
DASHBOARD_DEVICE_STATUS_REFRESH_MS=60000
# Device status-watch runs on the device only while an active dashboard tab is visible.
# Raise these values to reduce device chatter further.
DASHBOARD_STATUS_WATCH_INTERVAL_MS=45000
DASHBOARD_STATUS_WATCH_TTL_MS=180000
DASHBOARD_STATUS_WATCH_REFRESH_MS=120000
DEVICE_STATUS_AUTO_REFRESH_MS=
LOG_RETENTION_DAYS=30
LOG_LEVEL=info
TZ=Asia/Dhaka

# CORS (Socket.IO) — set to your dashboard's exact origin in production, e.g. https://dashboard.example.com
# Leave unset or empty to allow same-origin only
CORS_ORIGIN=
PUBLIC_BASE_URL=http://localhost:3001
OTA_BASE_URL=
# OTA_BASE_URL must be a public/routable URL reachable by the device. Localhost URLs work in the browser but fail on-device.
OTA_DOWNLOAD_SECRET=

# Authentication (CHANGE THESE before deploying!)
# Root dashboard account (created or updated on boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@example.com

# Legacy fallback for older deployments.
# These are only used when ADMIN_* is unset and do not seed a second superadmin account.
SUPER_USER=superadmin
SUPER_PASS=change-this-superadmin-password
SUPER_NAME=Super Administrator
SUPER_EMAIL=

# File Uploads
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./public/uploads
SD_CARD_PATH=/media/sd

# API Keys (for future use)
MAPBOX_API_KEY=your-mapbox-key
GOOGLE_MAPS_API_KEY=

# Optional notifications / integrations
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_TO=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
N8N_WEBHOOK_URL=
N8N_ENABLED=false
FCM_SERVER_KEY=
FIREBASE_SERVER_KEY=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_TOPIC=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY_PATH=
APNS_PRIVATE_KEY=
APNS_USE_PRODUCTION=false

# Provisioning / onboarding
# These control how the dashboard discovers setup transports.
DEVICE_SETUP_AP_IP=192.168.4.1
DEVICE_SETUP_AP_PREFIX=cfg
DEVICE_BLE_NAME_PREFIXES=Device-Setup,ESP32-Setup

# USB Serial Bridge (provisioning/debug/fallback only; main operations should use MQTT)
SERIAL_BRIDGE_ENABLED=false
SERIAL_BRIDGE_STATUS_FALLBACK=false
SERIAL_PORT=COM3          # Windows: COM3, COM4 …  Linux: /dev/ttyUSB0, /dev/ttyACM0
BLUETOOTH_SERIAL_PORT=    # Optional second config/provisioning port, e.g. COM4 or /dev/rfcomm0
SERIAL_BAUD=115200
RUNTIME_CONFIG_WIFI_ENABLED=false
RUNTIME_CONFIG_WIFI_TIMEOUT_MS=5000

# Script / utility helpers (optional)
# These are only for repo utilities and manual test helpers.
# They are not required for normal dashboard startup.
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
TARGET_PHONE=
USSD_CODE=
WIFI_SSID=
WIFI_PASSWORD=
HOTSPOT_SSID=
HOTSPOT_PASSWORD=
